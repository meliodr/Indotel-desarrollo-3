FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY INDOTEL.Web/INDOTEL.WEB.csproj INDOTEL.Web/
RUN dotnet restore INDOTEL.Web/INDOTEL.WEB.csproj

COPY INDOTEL.Web/ INDOTEL.Web/
RUN dotnet publish INDOTEL.Web/INDOTEL.WEB.csproj \
    --configuration Release \
    --no-restore \
    --output /app/publish \
    /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --system indotel \
    && useradd --system --gid indotel --home-dir /app indotel \
    && mkdir -p /app/.data-protection-keys \
    && chown -R indotel:indotel /app

COPY --from=build --chown=indotel:indotel /app/publish .

USER indotel
ENV ASPNETCORE_URLS=http://+:8080 \
    DOTNET_EnableDiagnostics=0
EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD curl --fail --silent http://127.0.0.1:8080/ || exit 1

ENTRYPOINT ["dotnet", "INDOTEL.WEB.dll"]
