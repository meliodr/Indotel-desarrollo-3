<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- Caja consume exclusivamente el API Gateway del despliegue release. -->
    <add key="ApiBaseUrl" value="https://localhost:8443/" />
    <add key="ApiTimeoutSeconds" value="20" />
    <add key="ApiConnectTimeoutSeconds" value="5" />
  </appSettings>
</configuration>
