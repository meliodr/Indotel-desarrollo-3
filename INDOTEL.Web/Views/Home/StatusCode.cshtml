@{
    ViewData["Title"] = ViewBag.Titulo ?? "Solicitud no completada";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-body p-4 p-md-5 text-center">
                    <div class="display-3 fw-bold text-secondary mb-2">@ViewBag.StatusCode</div>
                    <h1 class="h3 mb-3">@ViewBag.Titulo</h1>
                    <p class="text-muted mb-4">@ViewBag.Mensaje</p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                        Volver al inicio
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
