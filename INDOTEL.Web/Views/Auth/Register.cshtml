@model INDOTEL.WEB.Models.RegisterCiudadanoRequest

@{
    ViewData["Title"] = "Registro Ciudadano - Portal Digital";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0 fw-bold">Formulario de Registro</h4>
                    <small>Crea tu cuenta en el Sistema Digital INDOTEL</small>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Register" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2 small" role="alert"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Cedula" class="form-label fw-semibold">Cédula de Identidad</label>
                                <input asp-for="Cedula" type="text" class="form-control" placeholder="000-0000000-0" required />
                                <span asp-validation-for="Cedula" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Telefono" class="form-label fw-semibold">Teléfono de Contacto</label>
                                <input asp-for="Telefono" type="tel" class="form-control" placeholder="809-000-0000" required />
                                <span asp-validation-for="Telefono" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Nombres" class="form-label fw-semibold">Nombres</label>
                                <input asp-for="Nombres" type="text" class="form-control" placeholder="Nombre" required />
                                <span asp-validation-for="Nombres" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Apellidos" class="form-label fw-semibold">Apellidos</label>
                                <input asp-for="Apellidos" type="text" class="form-control" placeholder="Apellido" required />
                                <span asp-validation-for="Apellidos" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Correo" class="form-label fw-semibold">Correo Electrónico</label>
                            <input asp-for="Correo" type="email" class="form-control" placeholder="ejemplo@gmail.com" required />
                            <span asp-validation-for="Correo" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-semibold">Contraseña del Portal</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Mínimo 8 caracteres (letras y números)" required />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary py-2 fw-bold">Registrarse</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center py-3 bg-light border-0">
                    <p class="mb-0 small text-muted">¿Ya tienes una cuenta? <a asp-action="Login" class="text-primary fw-bold text-decoration-none">Inicia sesión aquí</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}