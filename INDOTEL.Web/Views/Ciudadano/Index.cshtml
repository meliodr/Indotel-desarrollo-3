@model INDOTEL.WEB.Models.DashboardViewModel

@{
    ViewData["Title"] = "Panel Ciudadano - INDOTEL";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h2 class="fw-bold text-dark">¡Hola, @Model.NombreCiudadano!</h2>
                <p class="text-muted mb-0">Aquí puedes registrar reclamaciones y consultar el avance de tus expedientes.</p>
            </div>
            <div>
                <a asp-action="Crear" asp-controller="Reclamacion" class="btn btn-primary fw-bold px-4 py-2 shadow-sm">
                    <i class="bi bi-plus-lg"></i> Nueva Reclamación
                </a>
            </div>
        </div>
    </div>

    @if (ViewBag.ErrorCore != null)
    {
        <div class="alert alert-warning p-3 small" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.ErrorCore
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm p-3 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="badge bg-primary p-3 me-3 text-white fs-4"><i class="bi bi-folder"></i></div>
                    <div>
                        <h6 class="text-muted mb-1 fw-semibold">Total de reclamaciones</h6>
                        <h3 class="mb-0 fw-bold text-dark">@Model.TotalReclamaciones</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm p-3 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="badge bg-warning p-3 me-3 text-dark fs-4"><i class="bi bi-clock-history"></i></div>
                    <div>
                        <h6 class="text-muted mb-1 fw-semibold">En proceso o pendientes</h6>
                        <h3 class="mb-0 fw-bold text-dark">@Model.TotalPendientes</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm p-3 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="badge bg-success p-3 me-3 text-white fs-4"><i class="bi bi-check-circle"></i></div>
                    <div>
                        <h6 class="text-muted mb-1 fw-semibold">Resueltas o cerradas</h6>
                        <h3 class="mb-0 fw-bold text-dark">@Model.TotalResueltas</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold text-secondary">Mis reclamaciones</h5>
            @if (Model.TotalPaginas > 0)
            {
                <span class="small text-muted">Página @Model.PaginaActual de @Model.TotalPaginas</span>
            }
        </div>
        <div class="card-body p-0">
            @if (Model.Reclamaciones.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">No. Expediente</th>
                                <th>Caso</th>
                                <th>Fecha</th>
                                <th>Estado</th>
                                <th class="text-end pe-4">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Reclamaciones)
                            {
                                var estado = (item.Estado ?? string.Empty).ToUpperInvariant();
                                <tr>
                                    <td class="ps-4 fw-bold text-primary">@item.NumeroExpediente</td>
                                    <td>
                                        <div class="fw-semibold text-dark">@(string.IsNullOrWhiteSpace(item.Titulo) ? "Reclamación ciudadana" : item.Titulo)</div>
                                        <div class="text-muted small text-truncate" style="max-width: 300px;">@item.Descripcion</div>
                                    </td>
                                    <td>@item.FechaCreacion.ToLocalTime().ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @if (estado is "RESUELTA" or "CERRADA")
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success px-2 py-1">@estado</span>
                                        }
                                        else if (estado is "RECIBIDA" or "VALIDADA" or "EN_REVISION_INDOTEL" or "ENVIADA_A_PRESTADORA" or "RESPONDIDA_POR_PRESTADORA")
                                        {
                                            <span class="badge bg-warning-subtle text-dark border border-warning px-2 py-1">@estado.Replace("_", " ")</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary border border-secondary px-2 py-1">@estado.Replace("_", " ")</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-action="Detalle" asp-controller="Reclamacion" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm fw-semibold">
                                            Ver detalles
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.TotalPaginas > 1)
                {
                    <nav class="p-3 border-top" aria-label="Paginación de reclamaciones">
                        <ul class="pagination justify-content-center mb-0">
                            <li class="page-item @(!Model.TienePaginaAnterior ? "disabled" : string.Empty)">
                                <a class="page-link" asp-action="Index" asp-route-page="@(Model.PaginaActual - 1)">Anterior</a>
                            </li>
                            <li class="page-item disabled"><span class="page-link">@Model.PaginaActual / @Model.TotalPaginas</span></li>
                            <li class="page-item @(!Model.TienePaginaSiguiente ? "disabled" : string.Empty)">
                                <a class="page-link" asp-action="Index" asp-route-page="@(Model.PaginaActual + 1)">Siguiente</a>
                            </li>
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-archive text-muted fs-1 mb-3 d-block"></i>
                    <p class="text-muted mb-0">No tienes reclamaciones registradas.</p>
                </div>
            }
        </div>
    </div>
</div>
