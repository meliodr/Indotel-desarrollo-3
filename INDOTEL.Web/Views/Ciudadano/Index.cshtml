@model INDOTEL.WEB.Models.DashboardViewModel

@{
    ViewData["Title"] = "Panel Ciudadano - INDOTEL";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold text-dark">¡Hola, @Model.NombreCiudadano!</h2>
                <p class="text-muted mb-0">Bienvenido al Portal Ciudadano. Aquí puedes gestionar y dar seguimiento a tus casos.</p>
            </div>
            <div>
                <a asp-action="Crear" asp-controller="Reclamacion" class="btn btn-primary fw-bold px-4 py-2 shadow-sm">
                    <i class="bi bi-plus-lg"></i> Nueva Reclamación
                </a>
            </div>
        </div>
    </div>

    @if (ViewBag.ErrorCore != null)
    {
        <div class="alert alert-warning p-3 small" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.ErrorCore
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm p-3 bg-white">
                <div class="d-flex align-items-center">
                    <div class="badge bg-primary p-3 me-3 text-white fs-4">
                        <i class="bi bi-folder"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1 fw-semibold">Total Solicitudes</h6>
                        <h3 class="mb-0 fw-bold text-dark">@Model.Reclamaciones.Count</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm p-3 bg-white">
                <div class="d-flex align-items-center">
                    <div class="badge bg-warning p-3 me-3 text-dark fs-4">
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1 fw-semibold">En Proceso / Pendientes</h6>
                        <h3 class="mb-0 fw-bold text-dark">@Model.TotalPendientes</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm p-3 bg-white">
                <div class="d-flex align-items-center">
                    <div class="badge bg-success p-3 me-3 text-white fs-4">
                        <i class="bi bi-check-circle"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1 fw-semibold">Casos Resueltos</h6>
                        <h3 class="mb-0 fw-bold text-dark">@Model.TotalResueltas</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3 border-0">
            <h5 class="mb-0 fw-bold text-secondary">Mis Reclamaciones Recientes</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Reclamaciones != null && Model.Reclamaciones.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">No. Expediente</th>
                                <th>Descripción Breve</th>
                                <th>Fecha Registro</th>
                                <th>Estado</th>
                                <th class="text-end pe-4">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Reclamaciones)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-primary">@item.NumeroExpediente</td>
                                    <td class="text-truncate" style="max-width: 250px;">@item.Descripcion</td>
                                    <td>@item.FechaCreacion.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @if (item.Estado.ToLower() == "resuelto")
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success px-2.5 py-1">Resuelto</span>
                                        }
                                        else if (item.Estado.ToLower() == "abierto" || item.Estado.ToLower() == "en proceso")
                                        {
                                            <span class="badge bg-warning-subtle text-warning border border-warning px-2.5 py-1">En proceso</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary border border-secondary px-2.5 py-1">@item.Estado</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-action="Detalle" asp-controller="Reclamacion" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm fw-semibold">
                                            Ver Detalles
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-archive text-muted fs-1 mb-3 d-block"></i>
                    <p class="text-muted mb-0">No tienes ninguna reclamación registrada en este momento.</p>
                </div>
            }
        </div>
    </div>
</div>