@model List<INDOTEL.WEB.Models.NotificacionDto>

@{
    ViewData["Title"] = "Mis Notificaciones - INDOTEL";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-2 fw-semibold">← Volver al Panel</a>
                    <h2 class="fw-bold text-dark mb-0">Centro de Notificaciones</h2>
                </div>
                <span class="badge bg-primary px-3 py-2 fw-semibold">@Model.Count(n => !n.Leida) Nuevas</span>
            </div>

            @if (ViewBag.ErrorCore != null)
            {
                <div class="alert alert-warning small" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.ErrorCore
                </div>
            }

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    @if (Model.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var notif in Model.OrderByDescending(n => n.Fecha))
                            {
                                <div class="list-group-item p-3 border-bottom @(notif.Leida ? "" : "bg-light-subtle border-start border-primary border-3")">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="me-3">
                                            @if (!notif.Leida)
                                            {
                                                <i class="bi bi-circle-fill text-primary small me-2" style="font-size: 0.6rem;"></i>
                                            }
                                            <div class="d-inline-block align-top">
                                                @if (!string.IsNullOrWhiteSpace(notif.Asunto))
                                                {
                                                    <div class="fw-bold small text-dark">@notif.Asunto</div>
                                                }
                                                <div class="@(notif.Leida ? "text-secondary" : "text-dark") small">@notif.Mensaje</div>
                                            </div>
                                        </div>
                                        <small class="text-muted text-nowrap ms-2" style="font-size: 0.75rem;">
                                            @notif.Fecha.ToLocalTime().ToString("dd/MM/yyyy hh:mm tt")
                                        </small>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-bell-slash text-muted fs-1 mb-3 d-block"></i>
                            <p class="text-muted mb-0">No tienes notificaciones registradas.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
