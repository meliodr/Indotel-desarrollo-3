@model List<INDOTEL.WEB.Models.NotificacionDto>

@{
    ViewData["Title"] = "Mis Notificaciones - INDOTEL";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-2 fw-semibold">← Volver al Panel</a>
                    <h2 class="fw-bold text-dark mb-0">Centro de Notificaciones</h2>
                </div>
                <span class="badge bg-primary px-3 py-2 fw-semibold">@Model.Count(n => !n.Leida) Nuevas</span>
            </div>

            @if (TempData["SuccessNotificacion"] is string successMessage)
            {
                <div class="alert alert-success small" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@successMessage
                </div>
            }

            @if (TempData["ErrorNotificacion"] is string errorMessage)
            {
                <div class="alert alert-warning small" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
                </div>
            }

            @if (ViewBag.ErrorCore != null)
            {
                <div class="alert alert-warning small" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.ErrorCore
                </div>
            }

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    @if (Model.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var notif in Model.OrderByDescending(n => n.Fecha))
                            {
                                <div class="list-group-item p-3 border-bottom @(notif.Leida ? "" : "bg-light-subtle border-start border-primary border-3")">
                                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3">
                                        <div class="me-md-3 flex-grow-1">
                                            @if (!notif.Leida)
                                            {
                                                <i class="bi bi-circle-fill text-primary small me-2" style="font-size: 0.6rem;"></i>
                                            }
                                            <div class="d-inline-block align-top">
                                                @if (!string.IsNullOrWhiteSpace(notif.Asunto))
                                                {
                                                    <div class="fw-bold small text-dark">@notif.Asunto</div>
                                                }
                                                <div class="@(notif.Leida ? "text-secondary" : "text-dark") small">@notif.Mensaje</div>
                                                <small class="text-muted d-block mt-1">
                                                    @notif.Fecha.ToLocalTime().ToString("dd/MM/yyyy hh:mm tt")
                                                </small>
                                            </div>
                                        </div>

                                        <div class="d-flex gap-2 flex-wrap justify-content-md-end">
                                            @if (notif.ReclamacionId.HasValue)
                                            {
                                                <a asp-controller="Reclamacion"
                                                   asp-action="Detalle"
                                                   asp-route-id="@notif.ReclamacionId.Value"
                                                   class="btn btn-sm btn-outline-secondary fw-semibold">
                                                    Ver Expediente
                                                </a>
                                            }

                                            @if (!notif.Leida)
                                            {
                                                <form asp-action="MarcarNotificacionLeida" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@notif.Id" />
                                                    <button type="submit" class="btn btn-sm btn-primary fw-semibold">
                                                        Marcar como leída
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success-subtle text-success border border-success align-self-center">
                                                    Leída
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-bell-slash text-muted fs-1 mb-3 d-block"></i>
                            <p class="text-muted mb-0">No tienes notificaciones registradas.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
